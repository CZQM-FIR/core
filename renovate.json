{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "matchUpdateTypes": [
        "patch",
        "pin",
        "digest",
        "minor",
        "lockFileMaintenance",
        "bump",
        "replacement",
        "pinDigest"
      ],
      "matchCurrentVersion": "!/^0/",
      "automerge": true
    }
  ],
  "prHourlyLimit": 5
}